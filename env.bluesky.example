# Bluesky credentials (100% FREE — no paid API)
#
# Setup (2 minutes):
#   1. Create account at https://bsky.app
#   2. Go to Settings → App Passwords → Add App Password
#   3. Copy the app password below

BSKY_HANDLE=youraccount.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# How often to post (minutes). Default: 180 (every 3 hours)
POST_INTERVAL_MINUTES=180

# Set to "true" to preview posts without sending
DRY_RUN=false

# Base URL for grow site links
POST_BASE_URL=https://grow.applyx.space
