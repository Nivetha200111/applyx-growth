# Twitter API credentials
# Get these from https://developer.x.com/en/portal/dashboard
# Create a project + app → Keys and tokens → Generate all 4 values
# Make sure your app has Read+Write permissions

TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# How often to tweet (in minutes). Default: 180 (every 3 hours)
TWEET_INTERVAL_MINUTES=180

# Set to "true" to preview tweets without posting
DRY_RUN=false

# Base URL for grow site links
TWEET_BASE_URL=https://grow.applyx.space
